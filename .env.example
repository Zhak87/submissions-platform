# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these under Project Settings -> API in the Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY is secret — never expose it to the client / commit it.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
