# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these under Project Settings -> API in the Supabase dashboard.
# SUPABASE_SERVICE_ROLE_KEY is secret — never expose it to the client / commit it.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Telegram notification on every new submission.
# TELEGRAM_BOT_TOKEN — from @BotFather after creating a bot.
# TELEGRAM_CHAT_ID — your numeric chat id, found via api.telegram.org/bot<token>/getUpdates
# after you've sent the bot at least one message. Leave both unset to disable.
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
